{
  "extends": ["html-validate:recommended"],
  "rules": {
    "no-inline-style": "off",
    "void-style": "off",
    "attribute-boolean-style": "off",
    "attribute-empty-style": "off",
    "attribute-misuse": "off",
    "long-title": "off",
    "no-trailing-whitespace": "off",
    "prefer-native-element": "off",
    "wcag/h30": "off",
    "wcag/h32": "off",
    "wcag/h37": "off",
    "wcag/h63": "off",
    "wcag/h67": "off"
  }
}
